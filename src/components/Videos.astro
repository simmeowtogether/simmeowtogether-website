---
import { videos } from "../data/videos";
---

<section id="videos" class="bg-slate-950 py-24">

  <div class="max-w-6xl mx-auto px-8">

    <h2 class="text-5xl font-black text-center mb-16">
      Latest Videos
    </h2>

    <div class="grid md:grid-cols-3 gap-8">

      {videos.map((video) => (

        <div class="bg-slate-800 rounded-2xl overflow-hidden shadow-xl hover:scale-105 transition duration-300">

          <img
            src={video.image}
            alt={video.title}
            class="w-full"
          />

          <div class="p-6">

            <h3 class="text-2xl font-bold mb-3">
              {video.title}
            </h3>

            <p class="text-gray-300 mb-6">
              {video.description}
            </p>

            <a
              href={video.url}
              target="_blank"
              class="text-red-500 font-bold hover:text-red-400"
            >
              ▶ Watch
            </a>

          </div>

        </div>

      ))}

    </div>

  </div>

</section>