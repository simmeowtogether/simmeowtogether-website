---
import { site } from "../data/site";
---

<section
id="hero"
class="relative min-h-screen bg-cover bg-center flex items-center justify-center"
style="background-image:url('/images/Banner.png');">

<div class="absolute inset-0 bg-black/65"></div>

<div class="relative z-10 text-center px-6">

<img
src="/images/Logo.jpg"
alt={site.name}
class="w-40 mx-auto mb-8 rounded-full shadow-2xl border-4 border-white"
/>

<h1 class="text-6xl md:text-8xl font-black text-white">
{site.name}
</h1>

<p class="mt-6 text-2xl text-gray-200">
{site.tagline}
</p>

<p class="mt-2 text-lg text-gray-300">
🇲🇲 {site.audience}
</p>

<div class="mt-10 flex justify-center gap-5 flex-wrap">

<a
href={site.youtube}
target="_blank"
class="bg-red-600 hover:bg-red-700 px-8 py-4 rounded-xl font-bold transition">

▶ Watch YouTube

</a>

<a
href={"mailto:" + site.email}
class="border border-white hover:bg-white hover:text-black px-8 py-4 rounded-xl font-bold transition">

🤝 Work With Us

</a>

</div>

</div>

</section>