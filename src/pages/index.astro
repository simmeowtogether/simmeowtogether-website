---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import WorkWithUs from "../components/WorkWithUs.astro";
import Hero from "../components/Hero.astro";
---

<Layout title="Simmeow Together">

<Navbar />

<Hero />

<section
id="about"
class="bg-slate-950 py-28">

<div class="max-w-5xl mx-auto px-8">

<h2 class="text-5xl font-black mb-8">
About Simmeow Together
</h2>

<p class="text-xl leading-9 text-gray-300">
Simmeow Together is a Burmese gaming content creator duo based in Thailand.

We create entertaining gameplay videos, livestreams, horror games, co-op adventures, and fun content for the Burmese gaming community.
</p>

</div>

</section>

<section id="stats" class="bg-slate-900 py-24">

<div class="max-w-6xl mx-auto px-8">

<h2 class="text-5xl font-black text-center mb-16">
Our Community
</h2>

<div class="grid md:grid-cols-3 gap-10">

<div class="bg-slate-800 rounded-2xl p-10 text-center shadow-xl">

<div class="text-6xl font-black text-red-500">
190K+
</div>

<p class="mt-4 text-gray-300">
YouTube Subscribers
</p>

</div>

<div class="bg-slate-800 rounded-2xl p-10 text-center shadow-xl">

<div class="text-6xl font-black text-red-500">
31M+
</div>

<p class="mt-4 text-gray-300">
Total Video Views
</p>

</div>

<div class="bg-slate-800 rounded-2xl p-10 text-center shadow-xl">

<div class="text-6xl font-black text-red-500">
🇲🇲
</div>

<p class="mt-4 text-gray-300">
Burmese Gaming Community
</p>

</div>

</div>

</div>

</section>

<section class="bg-slate-950 py-28">

<div class="max-w-7xl mx-auto px-8">

<h2 class="text-5xl font-black text-center mb-16">
Latest Videos
</h2>

<div class="grid md:grid-cols-3 gap-8">

<a
href="https://www.youtube.com/watch?v=pK8VsRKrJ3Y&list=PLH5pb3QqE3bFgTzxuNJaPhdd4Ajw3lH2w"
target="_blank"
class="group bg-slate-900 rounded-2xl overflow-hidden hover:scale-105 transition duration-300">

<img
src="/images/Banner.png"
class="w-full h-56 object-cover group-hover:brightness-110"
alt="Latest Video"
/>

<div class="p-6">

<h3 class="text-2xl font-bold">
🎮 Horror & Co-op Adventures
</h3>

<p class="mt-3 text-gray-400">

Watch our latest funny, horror and multiplayer gameplay videos.

</p>

</div>

</a>

<a
href="https://www.youtube.com/watch?v=E7U_cBo_w3w&list=PLH5pb3QqE3bE2rd796VSUmZra1psAnAP9"
target="_blank"
class="group bg-slate-900 rounded-2xl overflow-hidden hover:scale-105 transition duration-300">

<img
src="/images/Banner.png"
class="w-full h-56 object-cover group-hover:brightness-110"
alt="Latest Video"
/>

<div class="p-6">

<h3 class="text-2xl font-bold">
👻 Scary Games
</h3>

<p class="mt-3 text-gray-400">

Funny horror moments with Simba & Meow.

</p>

</div>

</a>

<a
href="https://www.youtube.com/watch?v=ejgG-zZD0og&list=PLH5pb3QqE3bFZ4rhGY2OKQB8CZR-s-tEU"
target="_blank"
class="group bg-slate-900 rounded-2xl overflow-hidden hover:scale-105 transition duration-300">

<img
src="/images/Banner.png"
class="w-full h-56 object-cover group-hover:brightness-110"
alt="Latest Video"
/>

<div class="p-6">

<h3 class="text-2xl font-bold">
🔥 Survival Games
</h3>

<p class="mt-3 text-gray-400">

Competitive gameplay and hilarious moments.

</p>

</div>

</a>

</div>

</div>

</section>

<section
id="team"
class="bg-slate-900 py-28">

<div class="max-w-7xl mx-auto px-8">

<h2 class="text-5xl font-black text-center mb-16">
Meet The Team
</h2>

<div class="grid md:grid-cols-2 gap-10">

<div class="bg-slate-800 rounded-3xl p-10">

<h3 class="text-4xl font-black mb-6">
🐺 Simba
</h3>

<p class="text-gray-300 leading-8">

Gaming streamer and co-founder of Simmeow Together.

Specializes in MMORPG, survival games, co-op adventures, and entertaining livestreams for the Burmese gaming community.

</p>

<div class="mt-8 flex flex-wrap gap-3">

<span class="bg-red-600 px-4 py-2 rounded-full">
MMORPG
</span>

<span class="bg-red-600 px-4 py-2 rounded-full">
Story Games
</span>

<span class="bg-red-600 px-4 py-2 rounded-full">
Livestreams
</span>

<span class="bg-red-600 px-4 py-2 rounded-full">
Co-op
</span>

</div>

</div>

<div class="bg-slate-800 rounded-3xl p-10">

<h3 class="text-4xl font-black mb-6">
🐱 Meow
</h3>

<p class="text-gray-300 leading-8">

Content creator and co-founder of Simmeow Together.
Specializes in Horror Games, Story Games.
Creates entertaining gameplay videos helps build a fun and welcoming gaming community.

</p>

<div class="mt-8 flex flex-wrap gap-3">

<span class="bg-red-600 px-4 py-2 rounded-full">
Gameplay
</span>

<span class="bg-red-600 px-4 py-2 rounded-full">
Editing
</span>

<span class="bg-red-600 px-4 py-2 rounded-full">
Creative
</span>

<span class="bg-red-600 px-4 py-2 rounded-full">
Horror
</span>

</div>

</div>

</div>

</div>

</section>

<WorkWithUs />

</Layout>